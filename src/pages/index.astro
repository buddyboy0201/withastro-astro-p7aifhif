---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Marquee from '../components/Marquee.astro';
import BurgundyBreak from '../components/BurgundyBreak.astro';
import content from '../content/pages/index.json';
import servicesContent from '../content/pages/services.json';
---

<BaseLayout title="Wellstead Marketing | Growth Marketing Agency" activeNav="home">
  <Hero
    subtitle={content.heroSubtitle}
    title={content.heroTitle}
    showCircleBtn={true}
  />

  <Marquee text={content.marqueeText} />

  <section class="section-pad">
    <div class="container split-section">
      <div class="sticky-side">
        <div class="editorial-heading">
          {content.introLabel}
          <span set:html={content.introHeading} />
        </div>
      </div>
      <div class="scroll-side">
        <p class="large-paragraph" set:html={content.introBody1} />
        <p class="large-paragraph" style="font-size: 1.5rem;">{content.introBody2}</p>
        <a href="/philosophy/" class="btn-sleek" style="background-color: transparent; border: 2px solid var(--primary-green); color: var(--primary-green);">
          Read Our Philosophy
        </a>
      </div>
    </div>
  </section>

  <BurgundyBreak heading={content.burgundyHeading} buttonText="View The Data" buttonUrl="/work/" />

  <section class="section-pad">
    <div class="container split-section">
      <div class="sticky-side">
        <div class="editorial-heading">
          {content.servicesLabel}
          <span set:html={content.servicesHeading} />
        </div>
        <p style="max-width: 300px; margin-top: 20px; font-size: 0.95rem;">{content.servicesSubtext}</p>
        <a href="/services/" class="btn-sleek" style="margin-top: 20px;">All Services</a>
      </div>
      <div class="scroll-side">
        {servicesContent.services.map((service) => (
          <div class="service-row" onclick={`window.location.href='/services/#${service.id}'`}>
            <div class="service-number">{service.number}</div>
            <h3 class="service-title">{service.title}</h3>
            <p class="service-desc">{service.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
